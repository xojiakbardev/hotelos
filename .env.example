# Copy to .env and adjust before running `docker compose up`.

# ---- Postgres ----
POSTGRES_USER=hotelos
POSTGRES_PASSWORD=hotelos_dev_pw
POSTGRES_DB=hotelos
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---- Redis (broker + cache) ----
REDIS_HOST=redis
REDIS_PORT=6379

# ---- Auth / JWT ----
# Shared symmetric secret used to sign and verify JWTs across services.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production-please-rotate-this-secret-now
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# ---- Service URLs (used by nginx upstreams; internal to compose network) ----
AUTH_SERVICE_URL=http://auth-service:8000
RECEPTION_SERVICE_URL=http://reception-service:8000
HOUSEKEEPING_SERVICE_URL=http://housekeeping-service:8000
ROOM_SERVICE_URL=http://room-service:8000
MAINTENANCE_SERVICE_URL=http://maintenance-service:8000
WS_GATEWAY_URL=http://ws-gateway:8000

# ---- Client (Vite dev) ----
VITE_API_BASE_URL=/api
VITE_WS_URL=/ws

# ---- Demo seed credentials (used by manage.py seedusers) ----
SEED_MANAGER_PHONE=+998901111111
SEED_MANAGER_PASSWORD=manager123
SEED_RECEPTION_PHONE=+998902222222
SEED_RECEPTION_PASSWORD=reception123
SEED_TECHNICIAN_PHONE=+998903333333
SEED_TECHNICIAN_PASSWORD=technician123
SEED_CLEANER_PHONE=+998904444444
SEED_CLEANER_PASSWORD=cleaner123
SEED_KITCHEN_PHONE=+998905555555
SEED_KITCHEN_PASSWORD=kitchen123
